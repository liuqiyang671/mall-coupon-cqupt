                  "pm.test(\"HTTP 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"business code is success\", () => pm.expect(String(json.code)).to.eql(pm.environment.get(\"successCode\")));",
                  "pm.test(\"coupon query returns available and unavailable lists\", () => {",
                  "  pm.expect(json.data.availableCoupons).to.be.an(\"array\");",
                  "  pm.expect(json.data.notAvailableCoupons).to.be.an(\"array\");",
                  "});",
                  "if (json.data.availableCoupons.length > 0) {",
                  "  pm.environment.set(\"applyCouponTemplateId\", String(json.data.availableCoupons[0].id));",
                  "} else {",
                  "  pm.environment.set(\"applyCouponTemplateId\", pm.environment.get(\"seedApplyCouponTemplateId\"));",
                  "}"
                ]
              }
            }
