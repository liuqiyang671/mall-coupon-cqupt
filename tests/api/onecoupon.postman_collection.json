  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = Date.now();",
          "if (!pm.environment.get(\"runId\")) { pm.environment.set(\"runId\", String(now)); }",
          "if (!pm.environment.get(\"merchantShopNumber\")) { pm.environment.set(\"merchantShopNumber\", pm.environment.get(\"shopNumber\")); }",
          "if (!pm.environment.get(\"customerUserId\")) { pm.environment.set(\"customerUserId\", pm.environment.get(\"seedCustomerUserId\")); }",
          "if (!pm.environment.get(\"cartId\")) { pm.environment.set(\"cartId\", pm.environment.get(\"seedCartId\")); }",
          "if (!pm.environment.get(\"applyCouponTemplateId\")) { pm.environment.set(\"applyCouponTemplateId\", pm.environment.get(\"seedApplyCouponTemplateId\")); }"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Merchant Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"business code is success\", () => pm.expect(String(json.code)).to.eql(pm.environment.get(\"successCode\")));",
                  "pm.test(\"login returns token and user id\", () => {",
                  "  pm.expect(json.data).to.be.an(\"object\");",
                  "  pm.expect(json.data.token).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(json.data.userId).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "pm.environment.set(\"merchantToken\", json.data.token);",
                  "pm.environment.set(\"merchantUserId\", String(json.data.userId));",
                  "pm.environment.set(\"merchantShopNumber\", pm.environment.get(\"shopNumber\"));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{merchantUsername}}\",\n  \"password\": \"{{merchantPassword}}\",\n  \"roleType\": {{merchantRoleType}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{merchantAdminBaseUrl}}/api/merchant-admin/user/login"
          }
        },
